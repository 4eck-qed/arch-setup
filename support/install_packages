#!/usr/bin/env bash
# Install packages one by one via an AUR helper.
#
# Usage: install_packages pkg1 pkg2 pkg3 ...
#
# Env:
#   AUR_HELPER                AUR helper to call (default: paru)
#   SEG_LABEL                 segment label used by the progress UI
#   ARCH_SETUP_PROGRESS_STATE if set, progress bars are updated per package
#                             (otherwise the fallback "== [pkg] (i/n)" lines
#                             are printed)

set -uo pipefail

AUR_HELPER="${AUR_HELPER:-paru}"
SEG_LABEL="${SEG_LABEL:-packages}"
MAX_RETRIES="${MAX_RETRIES:-3}"
RETRY_DELAY="${RETRY_DELAY:-30}"

THIS_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
PROGRESS="$THIS_DIR/progress"
progress_on=0
if [[ -n "${ARCH_SETUP_PROGRESS_STATE:-}" && -x "$PROGRESS" ]]; then
    progress_on=1
fi

if ! command -v "$AUR_HELPER" >/dev/null 2>&1; then
    echo "AUR helper '$AUR_HELPER' not found" >&2
    exit 1
fi

pkgs=("$@")
count=${#pkgs[@]}

if (( count == 0 )); then
    (( progress_on )) && "$PROGRESS" segment "$SEG_LABEL" 0
    exit 0
fi

if (( progress_on )); then
    "$PROGRESS" segment "$SEG_LABEL" "$count"
fi

install_pkg() {
    local pkg="$1" attempt=1
    while (( attempt <= MAX_RETRIES )); do
        if "$AUR_HELPER" -S --needed --noconfirm --overwrite '*' "$pkg"; then
            return 0
        fi
        if (( attempt < MAX_RETRIES )); then
            printf '   retrying %s in %ss (attempt %d/%d)\n' \
                "$pkg" "$RETRY_DELAY" "$attempt" "$MAX_RETRIES" >&2
            sleep "$RETRY_DELAY"
        fi
        attempt=$(( attempt + 1 ))
    done
    return 1
}

i=1
failed=()
for pkg in "${pkgs[@]}"; do
    if (( progress_on )); then
        printf '%s [%s/%s] %s: %s\n' '--' "$i" "$count" "$SEG_LABEL" "$pkg"
    else
        printf '== [%s] (%d/%d)\n' "$pkg" "$i" "$count"
    fi

    if ! install_pkg "$pkg"; then
        failed+=("$pkg")
    fi

    if (( progress_on )); then
        "$PROGRESS" step "$pkg"
    fi

    i=$((i + 1))
done

aur_reachable() {
    curl -sf --max-time 10 'https://aur.archlinux.org/rpc/v5/info' >/dev/null 2>&1
}

if (( ${#failed[@]} > 0 )); then
    while (( ${#failed[@]} > 0 )); do
        echo "" >&2
        echo "failed to install: ${failed[*]}" >&2
        echo "" >&2
        if ! aur_reachable; then
            echo "AUR (aur.archlinux.org) appears to be unreachable -- it may be under a DDoS attack or experiencing downtime." >&2
            echo "" >&2
        fi
        printf 'Retry %d failed package(s)? [y/N] ' "${#failed[@]}" >&2
        read -r answer </dev/tty || break
        case "$answer" in
            [yY]*) ;;
            *) break ;;
        esac

        retrying=("${failed[@]}")
        failed=()
        for pkg in "${retrying[@]}"; do
            if ! install_pkg "$pkg"; then
                failed+=("$pkg")
            fi
        done
    done

    if (( ${#failed[@]} > 0 )); then
        echo "" >&2
        echo "giving up on: ${failed[*]}" >&2
        exit 1
    fi
fi
