#!/usr/bin/env bash
# Keyboard-driven multi-select TUI.
#
# Usage: checkbox "Title"
# Reads items from stdin, one per line, tab-separated:
#     KEY<TAB>LABEL[<TAB>DEFAULT]
# DEFAULT: 1 = checked (default), 0 = unchecked.
#
# Prints selected KEYs to stdout, one per line.
# Interaction happens via /dev/tty, so stdin can be used for input.
#
# Controls:
#   j / down arrow    move down
#   k / up arrow      move up
#   space             toggle current
#   a                 select all
#   n                 select none
#   enter             confirm
#   q / ctrl-c        cancel (exit 130)

set -uo pipefail

title="${1:-Select items}"

keys=()
labels=()
states=()

while IFS=$'\t' read -r key label default; do
    [[ -z "${key:-}" ]] && continue
    keys+=("$key")
    labels+=("${label:-$key}")
    states+=("${default:-1}")
done

n=${#keys[@]}
if (( n == 0 )); then
    exit 0
fi

tty=/dev/tty
if ! stty_save=$( { stty -g <"$tty"; } 2>/dev/null); then
    # No tty: accept defaults and dump them out.
    for ((i = 0; i < n; i++)); do
        (( states[i] == 1 )) && printf '%s\n' "${keys[i]}"
    done
    exit 0
fi

cursor=0

# Raw mode on the tty (not on our stdin, which is the piped items).
cleanup() {
    stty "$stty_save" <"$tty" 2>/dev/null || true
    printf '\033[?25h' >"$tty"   # show cursor
    printf '\n' >"$tty"
}
trap 'cleanup; exit 130' INT TERM
trap cleanup EXIT
stty -echo -icanon min 1 time 0 <"$tty"
printf '\033[?25l' >"$tty"        # hide cursor

draw() {
    # Clear screen and paint the whole menu.
    printf '\033[2J\033[H' >"$tty"
    printf '\033[1m%s\033[0m\n' "$title" >"$tty"
    printf '\n' >"$tty"
    local i marker pointer
    for ((i = 0; i < n; i++)); do
        if (( states[i] == 1 )); then marker='x'; else marker=' '; fi
        if (( i == cursor )); then pointer='>'; else pointer=' '; fi
        if (( i == cursor )); then
            printf ' \033[36m%s\033[0m [%s] %s\n' "$pointer" "$marker" "${labels[i]}" >"$tty"
        else
            printf ' %s [%s] %s\n' "$pointer" "$marker" "${labels[i]}" >"$tty"
        fi
    done
    printf '\n\033[2m(j/k or arrows: move   space: toggle   a: all   n: none   enter: confirm   q: cancel)\033[0m\n' >"$tty"
}

read_key() {
    local key rest
    IFS= read -rsn1 key <"$tty" || return 1
    if [[ "$key" == $'\x1b' ]]; then
        # Escape sequence; try to read the rest (arrow keys).
        IFS= read -rsn2 -t 0.05 rest <"$tty" || rest=""
        printf '%s' "ESC:$rest"
        return 0
    fi
    printf '%s' "$key"
}

while true; do
    draw
    key="$(read_key)" || key=""
    case "$key" in
        'ESC:[A') (( cursor > 0 )) && cursor=$((cursor - 1)) ;;
        'ESC:[B') (( cursor < n - 1 )) && cursor=$((cursor + 1)) ;;
        'k')      (( cursor > 0 )) && cursor=$((cursor - 1)) ;;
        'j')      (( cursor < n - 1 )) && cursor=$((cursor + 1)) ;;
        ' ')      states[cursor]=$(( 1 - states[cursor] )) ;;
        'a')      for ((i = 0; i < n; i++)); do states[i]=1; done ;;
        'n')      for ((i = 0; i < n; i++)); do states[i]=0; done ;;
        ''|$'\n'|$'\r') break ;;
        'q')      exit 130 ;;
    esac
done

# Clear the menu so the answer doesn't sit on screen forever.
printf '\033[2J\033[H' >"$tty"

for ((i = 0; i < n; i++)); do
    (( states[i] == 1 )) && printf '%s\n' "${keys[i]}"
done
