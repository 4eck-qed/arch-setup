#!/usr/bin/env bash
set -euo pipefail

DOTFILES_URL="${DOTFILES_URL:-https://github.com/4eck-qed/dotfiles.git}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/dotfiles}"

if [[ -d "$DOTFILES_DIR/.git" ]]; then
    echo "-> dotfiles already cloned at $DOTFILES_DIR" >&2
else
    echo "-> cloning dotfiles into $DOTFILES_DIR" >&2
    git clone "$DOTFILES_URL" "$DOTFILES_DIR" >&2
fi

echo "-> syncing dotfiles submodules" >&2
git -C "$DOTFILES_DIR" submodule update --init --recursive >&2

echo "$DOTFILES_DIR"

