#################################################
#                   FUNCTIONS                   #
#################################################
enable_multilib() {
    local pacman_conf="/etc/pacman.conf"

    sudo -v

    if grep -qE '^\s*\[multilib\]' "$pacman_conf"; then
        echo "Multilib repository is already enabled."
    else
        sudo sed -i '/^#\[multilib\]/,/^#Include/{s/^#//}' "$pacman_conf"
        echo "Multilib repository enabled."
    fi

    sudo pacman -Syu --noconfirm
}

install_paru() {
    if command -v paru >/dev/null 2>&1; then
        echo "paru is already installed."
        return 0
    fi

    echo ">> Installing paru <<"
    sudo pacman -S --needed --noconfirm base-devel git

    local build_dir
    build_dir="$(mktemp -d)"
    trap 'rm -rf "$build_dir"' RETURN

    git clone https://aur.archlinux.org/paru.git "$build_dir/paru"
    (cd "$build_dir/paru" && makepkg -si --noconfirm)
}

install_zsh_plugins() {
    local base="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
    mkdir -p "$base"

    local -a repos=(
        "https://github.com/zsh-users/zsh-history-substring-search"
        "https://github.com/zsh-users/zsh-syntax-highlighting.git"
        "https://github.com/zsh-users/zsh-autosuggestions"
        "https://github.com/jirutka/zsh-shift-select.git"
    )

    for repo in "${repos[@]}"; do
        local name
        name="$(basename "$repo" .git)"
        if [[ ! -d "$base/$name/.git" ]]; then
            git clone --depth=1 "$repo" "$base/$name"
        else
            echo "$name already present - skipping."
        fi
    done
}

install_pkgs() {
    "$ROOT_DIR/support/install_packages" "$@"
}

# Pick NVIDIA kernel module variant from the installed GPU's architecture codename.
# Echoes "open" (Turing/Volta+) or "proprietary" (Pascal and older).
# Empty output = could not determine; caller should prompt.
detect_nvidia_driver() {
    command -v lspci >/dev/null 2>&1 || return 0

    local line arch
    line="$(lspci -nn | grep -i 'nvidia' | grep -iE 'vga|3d|display' | head -n 1 || true)"
    [[ -z "$line" ]] && return 0

    # pciutils embeds the chip codename (e.g. GA102, TU116, GP104) in the device name.
    arch="$(grep -oE '\b(GV|TU|GA|AD|GH|GB|GP|GM|GK|GF)[0-9]+' <<<"$line" | head -n 1 || true)"

    case "$arch" in
        GV*|TU*|GA*|AD*|GH*|GB*) echo "open" ;;
        GP*|GM*|GK*|GF*)         echo "proprietary" ;;
    esac
}

#################################################
#                    RUN                        #
#################################################
