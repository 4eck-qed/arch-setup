GPU_VENDORS=("$@") # one or more of: nvidia, amd, intel
(( ${#GPU_VENDORS[@]} > 0 )) || {
    echo "no gpu vendors provided - available: nvidia,amd,intel" >&2
    exit 1
}
for v in "${GPU_VENDORS[@]}"; do
    case "$v" in
        nvidia|amd|intel) ;;
        *) echo "unknown gpu '$v' - available: nvidia,amd,intel" >&2; exit 1 ;;
    esac
done

