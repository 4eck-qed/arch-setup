#!/usr/bin/env bash
set -uo pipefail

THIS_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
ROOT_DIR="$(cd -- "$THIS_DIR/.." && pwd)"
DOTFILES_DIR="$ROOT_DIR/dotfiles"
INSTALL_PKGS="$ROOT_DIR/support/install_packages"

# ---- inputs ----------------------------------------------------------
# GPU_VENDORS: pass as positional args OR CORE_GPU_VENDORS env (space-separated).
# Accepted values: nvidia, amd, intel.
GPU_VENDORS=("$@")
if (( ${#GPU_VENDORS[@]} == 0 )) && [[ -n "${CORE_GPU_VENDORS:-}" ]]; then
    read -ra GPU_VENDORS <<<"$CORE_GPU_VENDORS"
fi

# CORE_PHASE: install (default) | count | list-dev | list-opt
PHASE="${CORE_PHASE:-install}"

# CORE_DEV_GROUPS / CORE_OPT_GROUPS: space-separated group keys.
# Empty/unset = install everything in that category.
# "none" or "-" = install nothing in that category.
DEV_SEL="${CORE_DEV_GROUPS-__all__}"
OPT_SEL="${CORE_OPT_GROUPS-__all__}"

# CORE_NVIDIA_VARIANT: "open" | "proprietary" | "" (auto-detect / prompt)
NVIDIA_VARIANT="${CORE_NVIDIA_VARIANT:-}"

#################################################
#                   PACKAGES                    #
#################################################

# ---- Networking ----------------------------------------
NETWORK=(
    networkmanager              # NM daemon (wifi/ethernet)
    network-manager-applet      # tray GUI for NM
    openssh                     # ssh client + sshd
)

# ---- Shell / CLI utilities -----------------------------
CORE_UTILS=(
    curl                        # HTTP client
    wget                        # HTTP downloader
    rsync                       # file sync / backups
    less                        # pager
    unzip                       # .zip extraction
    unrar                       # .rar extraction
    7zip
    cpio                        # copy files into or out of cpio/tar archives
    man-db                      # man page tooling
    man-pages                   # Linux man pages
    bat                         # cat with syntax highlighting
    ripgrep                     # fast grep (rg)
    fd                          # fast find (fd)
    lsd                         # ls with icons
    tree                        # directory tree printer
    btop                        # system resource monitor
    fastfetch                   # system info
    mc                          # midnight commander (TUI file manager)
    flatpak                     # flatpak runtime + CLI
    mono
)

# ---- XDG / desktop integration -------------------------
XDG=(
    xdg-user-dirs
    xdg-utils
    gvfs
    gvfs-mtp
    gvfs-smb
    tumbler
)

# ---- Core desktop (FM + terminal + launcher) -----------
DESKTOP=(
    polkit
    thunar
    thunar-archive-plugin
    ark
    alacritty
    ulauncher
)

# ---- Fonts ---------------------------------------------
FONTS=(
    fontconfig
    ttf-liberation
    ttf-dejavu
    noto-fonts
    noto-fonts-emoji
    noto-fonts-cjk
    ttf-nerd-fonts-symbols
    ttf-nerd-fonts-symbols-mono
    otf-font-awesome
    ttf-jetbrains-mono-nerd
    ttf-iosevka-nerd
    ttf-ubuntu-font-family
    ttf-inconsolata
    ttf-fira-code
    ttf-hack-nerd
    otf-hasklig
    cantarell-fonts
)

# ---- Security ------------------------------------------
SECURITY=(
    chkrootkit
    rkhunter
)

# ---- Audio (pipewire stack) ----------------------------
AUDIO=(
    pipewire
    pipewire-alsa
    pipewire-jack
    pipewire-pulse
    wireplumber
    pavucontrol
)

# ---- GPU: Nvidia ---------------------------------------
GPU_NVIDIA=(
    dkms
    nvidia-utils
    lib32-nvidia-utils
    nvidia-settings
    libva-nvidia-driver
)
GPU_NVIDIA_OPEN=(nvidia-open-dkms)
GPU_NVIDIA_PROPRIETARY=(nvidia-dkms)

# ---- GPU: AMD ------------------------------------------
GPU_AMD=(
    mesa
    lib32-mesa
    vulkan-radeon
    lib32-vulkan-radeon
    amd-ucode
    linux-firmware
    mesa-utils
    vulkan-mesa-layers
    lib32-vulkan-mesa-layers
    libva-mesa-driver
    lib32-libva-mesa-driver
    mesa-vdpau
    lib32-mesa-vdpau
    radeontop
)

# ---- GPU: Intel ----------------------------------------
GPU_INTEL=(
    mesa
    lib32-mesa
    vulkan-intel
    lib32-vulkan-intel
    intel-media-driver
    mesa-utils
    vulkan-mesa-layers
    lib32-vulkan-mesa-layers
    intel-gpu-tools
)

# ---- Hardware monitoring -------------------------------
MONITORING=(
    lm_sensors
)

# ---- Dev groups -----------------------------------------
DEV_VCS=(git-credential-oauth gitui)
DEV_C_CPP=(clang llvm cmake cmake-format ninja make astyle)
DEV_DOTNET=(dotnet-host dotnet-runtime dotnet-sdk dotnet-targeting-pack aspnet-runtime aspnet-targeting-pack netstandard-targeting-pack nuget)
DEV_RUST=(rustup)
DEV_PYTHON=(python python-packaging python-black)
DEV_LUA=(lua luarocks stylua)
DEV_JS=(nodejs npm nvm typescript prettier)
DEV_EDITOR=(neovim code-minimap)

# Registry: key | label | array-name
DEV_GROUPS=(
    "vcs|Version control (gitui, git-credential-oauth)|DEV_VCS"
    "c_cpp|C / C++ (clang, llvm, cmake, ninja, ...)|DEV_C_CPP"
    "dotnet|.NET SDK + runtime|DEV_DOTNET"
    "rust|Rust (rustup)|DEV_RUST"
    "python|Python (python, black)|DEV_PYTHON"
    "lua|Lua (lua, luarocks, stylua)|DEV_LUA"
    "js|JavaScript / TypeScript (node, npm, nvm, tsc, prettier)|DEV_JS"
    "editor|Neovim + code-minimap|DEV_EDITOR"
)

# ---- Optional groups -----------------------------------
OPT_BROWSERS=(brave-bin)
OPT_JAVA=(jdk-openjdk)
OPT_WALLET=(kwallet-pam kwalletmanager)
OPT_MEDIA_CREATION=(obs-studio audacity pinta)
OPT_MEDIA_PLAYBACK=(vlc vlc-plugins-all ffmpeg gst-plugins-good gst-plugins-bad-libs)
OPT_GAMING=(steam lutris wine wine-mono wine-gecko)

OPT_GROUPS=(
    "browsers|Browsers (brave)|OPT_BROWSERS"
    "java|Java (jdk-openjdk)|OPT_JAVA"
    "wallet|KDE wallet (brave/chrome integration)|OPT_WALLET"
    "media_creation|Media creation (obs, audacity, pinta)|OPT_MEDIA_CREATION"
    "media_playback|Media playback (vlc, ffmpeg, gstreamer)|OPT_MEDIA_PLAYBACK"
    "gaming|Gaming (steam, lutris, wine)|OPT_GAMING"
)

#################################################
#                   HELPERS                     #
#################################################
is_selected() {
    # is_selected KEY SEL_STRING
    local key="$1" sel="$2"
    case "$sel" in
        __all__)       return 0 ;;
        ''|none|'-')   return 1 ;;
    esac
    local w
    for w in $sel; do
        [[ "$w" == "$key" ]] && return 0
    done
    return 1
}

# Echoes the chosen NVIDIA variant (open/proprietary/"").
detect_nvidia_driver() {
    command -v lspci >/dev/null 2>&1 || return 0
    local line arch
    line="$(lspci -nn | grep -i 'nvidia' | grep -iE 'vga|3d|display' | head -n 1 || true)"
    [[ -z "$line" ]] && return 0
    arch="$(grep -oE '\b(GV|TU|GA|AD|GH|GB|GP|GM|GK|GF)[0-9]+' <<<"$line" | head -n 1 || true)"
    case "$arch" in
        GV*|TU*|GA*|AD*|GH*|GB*) echo "open" ;;
        GP*|GM*|GK*|GF*)         echo "proprietary" ;;
    esac
}

gpu_pkgs_for() {
    # Echo the packages for a single vendor (one per line). For NVIDIA, uses
    # $NVIDIA_VARIANT (falls back to detection, otherwise "open").
    local v="$1"
    case "$v" in
        nvidia)
            local variant="$NVIDIA_VARIANT"
            if [[ -z "$variant" ]]; then
                variant="$(detect_nvidia_driver)"
            fi
            [[ -z "$variant" ]] && variant="open"
            printf '%s\n' "${GPU_NVIDIA[@]}"
            case "$variant" in
                open)        printf '%s\n' "${GPU_NVIDIA_OPEN[@]}" ;;
                proprietary) printf '%s\n' "${GPU_NVIDIA_PROPRIETARY[@]}" ;;
            esac
            ;;
        amd)   printf '%s\n' "${GPU_AMD[@]}" ;;
        intel) printf '%s\n' "${GPU_INTEL[@]}" ;;
    esac
}

install_section() {
    # install_section "Label" pkg1 pkg2 ...
    local label="$1"; shift
    SEG_LABEL="$label" "$INSTALL_PKGS" "$@"
}

# Resolve the concrete package list that install will use (for counting).
resolve_all_pkgs() {
    local -a all=()

    # install_section "base" zsh git base-devel
    all+=(zsh git base-devel)

    all+=("${NETWORK[@]}")
    all+=("${CORE_UTILS[@]}")
    all+=("${XDG[@]}")
    all+=("${DESKTOP[@]}")
    all+=("${FONTS[@]}")
    all+=("${SECURITY[@]}")
    all+=("${AUDIO[@]}")

    local v
    for v in "${GPU_VENDORS[@]}"; do
        case "$v" in
            nvidia|amd|intel)
                mapfile -t tmp < <(gpu_pkgs_for "$v")
                all+=("${tmp[@]}")
                ;;
        esac
    done

    all+=("${MONITORING[@]}")

    local entry key arr_name
    for entry in "${DEV_GROUPS[@]}"; do
        IFS='|' read -r key _ arr_name <<<"$entry"
        is_selected "$key" "$DEV_SEL" || continue
        eval "all+=(\"\${${arr_name}[@]}\")"
    done
    for entry in "${OPT_GROUPS[@]}"; do
        IFS='|' read -r key _ arr_name <<<"$entry"
        is_selected "$key" "$OPT_SEL" || continue
        eval "all+=(\"\${${arr_name}[@]}\")"
    done

    printf '%s\n' "${all[@]}"
}

#################################################
#           LIST / COUNT SUBCOMMANDS            #
#################################################
case "$PHASE" in
    list-dev)
        for entry in "${DEV_GROUPS[@]}"; do
            IFS='|' read -r key label _ <<<"$entry"
            printf '%s\t%s\n' "$key" "$label"
        done
        exit 0
        ;;
    list-opt)
        for entry in "${OPT_GROUPS[@]}"; do
            IFS='|' read -r key label _ <<<"$entry"
            printf '%s\t%s\n' "$key" "$label"
        done
        exit 0
        ;;
    count)
        resolve_all_pkgs | wc -l
        exit 0
        ;;
    install)
        ;;
    *)
        echo "unknown CORE_PHASE: $PHASE (expected: install|count|list-dev|list-opt)" >&2
        exit 2
        ;;
esac

#################################################
#             VALIDATE INSTALL INPUTS           #
#################################################
if (( ${#GPU_VENDORS[@]} == 0 )); then
    echo "no gpu vendors provided - available: nvidia,amd,intel" >&2
    exit 1
fi
for v in "${GPU_VENDORS[@]}"; do
    case "$v" in
        nvidia|amd|intel) ;;
        *) echo "unknown gpu '$v' - available: nvidia,amd,intel" >&2; exit 1 ;;
    esac
done

#################################################
#                 INSTALL HELPERS               #
#################################################
enable_multilib() {
    local pacman_conf="/etc/pacman.conf"
    sudo -v
    if grep -qE '^\s*\[multilib\]' "$pacman_conf"; then
        echo "Multilib repository is already enabled."
    else
        sudo sed -i '/^#\[multilib\]/,/^#Include/{s/^#//}' "$pacman_conf"
        echo "Multilib repository enabled."
    fi
    sudo pacman -Syu --noconfirm
}

install_paru() {
    if command -v paru >/dev/null 2>&1; then
        echo "paru is already installed."
        return 0
    fi
    echo ">> Installing paru <<"
    sudo pacman -S --needed --noconfirm base-devel git
    local build_dir
    build_dir="$(mktemp -d)"
    trap 'rm -rf "$build_dir"' RETURN
    git clone https://aur.archlinux.org/paru.git "$build_dir/paru"
    (cd "$build_dir/paru" && makepkg -si --noconfirm)
}

install_zsh_plugins() {
    local base="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
    mkdir -p "$base"
    local -a repos=(
        "https://github.com/zsh-users/zsh-history-substring-search"
        "https://github.com/zsh-users/zsh-syntax-highlighting.git"
        "https://github.com/zsh-users/zsh-autosuggestions"
        "https://github.com/jirutka/zsh-shift-select.git"
    )
    for repo in "${repos[@]}"; do
        local name
        name="$(basename "$repo" .git)"
        if [[ ! -d "$base/$name/.git" ]]; then
            git clone --depth=1 "$repo" "$base/$name"
        else
            echo "$name already present - skipping."
        fi
    done
}

#################################################
#                    RUN                        #
#################################################
enable_multilib
install_paru

install_section "base" zsh git base-devel

install_section "Networking" "${NETWORK[@]}"
sudo systemctl enable --now NetworkManager || true

install_section "Shell / CLI utilities" "${CORE_UTILS[@]}"
install_section "XDG / desktop integration" "${XDG[@]}"
install_section "Core desktop" "${DESKTOP[@]}"

install_section "Fonts" "${FONTS[@]}"
fc-cache -fv

install_section "Security" "${SECURITY[@]}"
install_section "Audio" "${AUDIO[@]}"

for v in "${GPU_VENDORS[@]}"; do
    case "$v" in
        nvidia)
            if [[ -z "$NVIDIA_VARIANT" ]]; then
                NVIDIA_VARIANT="$(detect_nvidia_driver)"
            fi
            if [[ -z "$NVIDIA_VARIANT" ]]; then
                echo "Could not auto-detect NVIDIA GPU generation."
                if "$ROOT_DIR/support/prompt" "Use nvidia-open-dkms? [y=open (Turing/20xx+), n=proprietary nvidia-dkms (Pascal/older)]"; then
                    NVIDIA_VARIANT="open"
                else
                    NVIDIA_VARIANT="proprietary"
                fi
            fi
            echo "NVIDIA kernel module variant: $NVIDIA_VARIANT"
            case "$NVIDIA_VARIANT" in
                open)        install_section "GPU (nvidia-open)"        "${GPU_NVIDIA[@]}" "${GPU_NVIDIA_OPEN[@]}" ;;
                proprietary) install_section "GPU (nvidia-proprietary)" "${GPU_NVIDIA[@]}" "${GPU_NVIDIA_PROPRIETARY[@]}" ;;
            esac
            ;;
        amd)   install_section "GPU (amd)"   "${GPU_AMD[@]}" ;;
        intel) install_section "GPU (intel)" "${GPU_INTEL[@]}" ;;
    esac
done

install_section "Hardware monitoring" "${MONITORING[@]}"

# ---- Dev groups ----
for entry in "${DEV_GROUPS[@]}"; do
    IFS='|' read -r key label arr_name <<<"$entry"
    is_selected "$key" "$DEV_SEL" || continue
    eval "pkgs=(\"\${${arr_name}[@]}\")"
    install_section "Dev: $label" "${pkgs[@]}"
done

git-credential-oauth configure || true

# ---- Optional groups ----
for entry in "${OPT_GROUPS[@]}"; do
    IFS='|' read -r key label arr_name <<<"$entry"
    is_selected "$key" "$OPT_SEL" || continue
    eval "pkgs=(\"\${${arr_name}[@]}\")"
    install_section "Opt: $label" "${pkgs[@]}"
done

install_zsh_plugins

echo "--- core done ---"
