#!/usr/bin/env bash
set -euo pipefail

THIS_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
ROOT_DIR="$(cd -- "$THIS_DIR/../.." && pwd)"
INSTALL_PKGS="$ROOT_DIR/support/install_packages"

# dwm and bar are built from source (suckless patches), so only deps here.
PKGS=(
    libxft                  # font rendering (dwm status bar)
    libxinerama             # multi-monitor support
)

if [[ "${COUNT_ONLY:-0}" == "1" ]]; then
    base_count="$(COUNT_ONLY=1 "$THIS_DIR/base")"
    printf '%s\n' "$(( base_count + ${#PKGS[@]} ))"
    exit 0
fi

"$THIS_DIR/base"

SEG_LABEL="dwm" "$INSTALL_PKGS" "${PKGS[@]}"
