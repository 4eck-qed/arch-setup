#!/usr/bin/env bash
set -euo pipefail

THIS_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"
ROOT_DIR="$(cd -- "$THIS_DIR/../.." && pwd)"
INSTALL_PKGS="$ROOT_DIR/support/install_packages"

PKGS=(
    polybar                 # status bar
    bspwm                   # tiling window manager
    sxhkd                   # hotkey daemon
    rofi                    # launcher / window switcher / runner (X11)
    stalonetray             # standalone system tray
    pamixer                 # pulse/pipewire volume control (CLI)
)

if [[ "${COUNT_ONLY:-0}" == "1" ]]; then
    base_count="$(COUNT_ONLY=1 "$THIS_DIR/base")"
    printf '%s\n' "$(( base_count + ${#PKGS[@]} ))"
    exit 0
fi

"$THIS_DIR/base"

SEG_LABEL="bspwm" "$INSTALL_PKGS" "${PKGS[@]}"
